rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LuxWalls Security Rules Architecture
     * Updated for high-performance public metrics and anonymous session consistency.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // Wallpapers: Publicly readable, admin-only writes
    match /wallpapers/{wallpaperId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    // Hero Images: Publicly readable, admin-only writes
    match /hero_images/{heroImageId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Publicly accessible metrics (Views, Downloads, Likes).
     * Allows anyone to view and increment stats.
     */
    match /stats/{wallpaperId} {
      allow read, write: if true;
    }

    /**
     * @description Legacy likes support.
     */
    match /likes/{wallpaperId} {
      allow read, write: if true;
    }

    match /roles_admin/{uid} {
      allow get: if isSignedIn() && request.auth.uid == uid;
      allow list: if false;
      allow create, update, delete: if false;
    }
  }
}